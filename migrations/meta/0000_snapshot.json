  "views": {
    "public.daily_nutrition": {
      "columns": {
        "day": {
          "name": "day",
          "type": "date",
          "primaryKey": false,
          "notNull": true
        },
        "kcal": {
          "name": "kcal",
          "type": "numeric(7, 1)",
          "primaryKey": false,
          "notNull": true
        },
        "protein_g": {
          "name": "protein_g",
          "type": "numeric(6, 1)",
          "primaryKey": false,
          "notNull": true
        },
        "meal_count": {
          "name": "meal_count",
          "type": "numeric",
          "primaryKey": false,
          "notNull": true
        }
      },
      "definition": "\n\t\tselect\n\t\t\tdate_trunc('day', m.eaten_at at time zone 'Europe/Lisbon')::date as day,\n\t\t\tsum(mi.kcal)::numeric(7, 1) as kcal,\n\t\t\tsum(mi.protein_g)::numeric(6, 1) as protein_g,\n\t\t\tcount(distinct m.id) as meal_count\n\t\tfrom meals m\n\t\tjoin meal_items mi on mi.meal_id = m.id\n\t\tgroup by 1\n\t",
      "name": "daily_nutrition",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    },
