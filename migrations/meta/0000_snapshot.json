      "definition": "\n\t\tselect distinct on (metric)\n\t\t\tmetric,\n\t\t\ttarget_value,\n\t\t\ttarget_date,\n\t\t\teffective_from,\n\t\t\teffective_to\n\t\tfrom goals\n\t\twhere current_date >= effective_from\n\t\t\tand (effective_to is null or current_date < effective_to)\n\t\torder by metric, effective_from desc\n\t",
      "name": "goals_active",
