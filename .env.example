# Copy this file to .env.local for local development.
# .env.local is .gitignore'd. NEVER commit real secrets.
# In production, all of these come from Kubernetes Secrets (see docs/DEPLOY.md).

# ─── Database ─────────────────────────────────────────────────────────────
# Local dev points at the docker-compose postgres on localhost:5432.
DATABASE_URL=postgres://health:health@localhost:5432/health

# ─── HealthAutoExport ingest bearer ───────────────────────────────────────
# Generate a real one with `openssl rand -hex 32` for prod.
# `devtoken` is fine for local curl/HAE testing.
INGEST_TOKEN=devtoken

# ─── Auth shim (dev only) ────────────────────────────────────────────────
# In prod, identity comes from the Cf-Access-Authenticated-User-Email header.
# Locally, we bypass Cloudflare Access and use these instead.
# hooks.server.ts will only honour these when NODE_ENV !== 'production'.
DEV_SKIP_CF_ACCESS=1
DEV_USER_EMAIL=you@example.com

# ─── Telegram bot (optional in dev) ──────────────────────────────────────
# Leave blank to disable. Create a bot via @BotFather to fill these in.
# See docs/REMINDERS.md.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
TZ=Europe/Lisbon
